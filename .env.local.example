# Google Analytics 4
# Get your Measurement ID from: https://analytics.google.com → Admin → Data Streams → Web
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Formspree contact form
# 1. Go to https://formspree.io → Create account → New Form
# 2. Copy the form ID (the part after /f/ in the endpoint URL)
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here

# Resend — newsletter signup
# 1. Get an API key at https://resend.com/api-keys (server-only, do NOT prefix with NEXT_PUBLIC_)
# 2. Optional: create an audience and copy its ID from https://resend.com/audiences
# 3. Optional: override the From address (must be from a verified domain)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=Patrik Přikryl <newsletter@patrikprikryl.com>
